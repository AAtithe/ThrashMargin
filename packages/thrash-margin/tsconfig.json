{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "shared/*": ["./shared/*"]
    }
  },
  "include": ["api/**/*", "shared/**/*"],
  "exclude": ["client", "server", "node_modules"]
}
