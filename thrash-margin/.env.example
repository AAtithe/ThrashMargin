# Copy to .env.local for local development with `vercel dev`

# Supabase — use the "Transaction mode" pooler URL from:
# Supabase dashboard → Settings → Database → Connection string → Transaction mode
# It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:3000
